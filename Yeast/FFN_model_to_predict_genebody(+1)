
import pandas as pd
import numpy as np

import torch
import torch.nn as nn
import torch.optim as optim

from sklearn.model_selection import KFold
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import r2_score


df = pd.read_csv('/Users/khusbuagarwal/Downloads/yeast_db.csv')

time_row = df.iloc[0]
data = df.iloc[1:].copy()

data['gene_pos'] = pd.to_numeric(data['gene_pos'], errors='coerce')

start_index = df.columns.get_loc("gene_pos") + 1

ptm_zero_cols = []

for col in df.columns[start_index:]:

    if col.lower().startswith("input"):
        continue

    try:
        if float(time_row[col]) == 0:
            ptm_zero_cols.append(col)
    except:
        pass


positions = [-3,-2,-1,1,2,3]

subset = data[data['gene_pos'].isin(positions)]
subset = subset[['gene','gene_pos'] + ptm_zero_cols]

pivot_df = subset.pivot_table(index='gene', columns='gene_pos', aggfunc='mean')


device = torch.device("cuda" if torch.cuda.is_available() else "cpu")


class FFN(nn.Module):

    def __init__(self,input_dim):

        super().__init__()

        self.net = nn.Sequential(

            nn.Linear(input_dim,128),
            nn.ReLU(),

            nn.Linear(128,64),
            nn.ReLU(),

            nn.Linear(64,32),
            nn.ReLU(),

            nn.Linear(32,1)

        )

    def forward(self,x):

        return self.net(x)


def train_model(model,X_train,y_train,X_test,epochs=200):

    model = model.to(device)

    criterion = nn.MSELoss()

    optimizer = optim.Adam(model.parameters(),lr=0.001)

    X_train = torch.tensor(X_train,dtype=torch.float32).to(device)
    y_train = torch.tensor(y_train,dtype=torch.float32).view(-1,1).to(device)

    X_test = torch.tensor(X_test,dtype=torch.float32).to(device)

    for epoch in range(epochs):

        model.train()

        optimizer.zero_grad()

        preds = model(X_train)

        loss = criterion(preds,y_train)

        loss.backward()

        optimizer.step()

    model.eval()

    with torch.no_grad():

        preds = model(X_test).cpu().numpy().flatten()

    return preds


kf = KFold(n_splits=5, shuffle=True, random_state=42)

results = []

unique_ptms = pivot_df.columns.get_level_values(0).unique()


for ptm in unique_ptms:

    try:

        ptm_df = pivot_df[ptm]

        if 1 not in ptm_df.columns:
            continue

        feature_positions = [-3,-2,-1,2,3]

        for pos in feature_positions:
            if pos not in ptm_df.columns:
                ptm_df[pos] = 0

        ptm_df = ptm_df[feature_positions + [1]]

        ptm_df = ptm_df.dropna(subset=[1])

        ptm_df[feature_positions] = ptm_df[feature_positions].fillna(0)

        X = ptm_df[feature_positions].values
        y = ptm_df[1].values

        X = np.nan_to_num(X)
        y = np.nan_to_num(y)

        scaler = StandardScaler()

        X = scaler.fit_transform(X)

        scores = []

        for train_idx,test_idx in kf.split(X):

            X_train,X_test = X[train_idx],X[test_idx]
            y_train,y_test = y[train_idx],y[test_idx]

            model = FFN(X.shape[1])

            preds = train_model(model,X_train,y_train,X_test)

            score = r2_score(y_test,preds)

            scores.append(score)

        mean_r2 = np.mean(scores)

        print("PTM:",ptm)
        print("Mean R2:",mean_r2)

        results.append({
            "PTM":ptm,
            "Genes":len(y),
            "Mean_R2":mean_r2,
            "Std_R2":np.std(scores)
        })

    except:
        continue


results_df = pd.DataFrame(results)

results_df = results_df.sort_values(by="Mean_R2",ascending=False)

print(results_df.head(20))

results_df.to_csv("PTM_plus1_prediction_results.csv",index=False)

