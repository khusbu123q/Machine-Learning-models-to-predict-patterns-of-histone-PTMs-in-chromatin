import pandas as pd
import numpy as np

import torch
import torch.nn as nn
import torch.optim as optim

from sklearn.model_selection import KFold
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import r2_score


# LOAD DATA

df = pd.read_csv('/Users/khusbuagarwal/Downloads/yeast_db.csv')

time_row = df.iloc[0]
data = df.iloc[1:].copy()

data['gene_pos'] = pd.to_numeric(data['gene_pos'], errors='coerce')

# IDENTIFY PTM COLUMNS AT TIMEPOINT 0

start_index = df.columns.get_loc("gene_pos") + 1

ptm_zero_cols = []

for col in df.columns[start_index:]:

    if col.lower().startswith("input"):
        continue

    try:
        if float(time_row[col]) == 0:
            ptm_zero_cols.append(col)
    except:
        pass

print("Total PTMs detected:", len(ptm_zero_cols))

# SELECT POSITIONS

positions = [-1,1,2,3,4,5]

subset = data[data['gene_pos'].isin(positions)]
subset = subset[['gene','gene_pos'] + ptm_zero_cols]

pivot_df = subset.pivot_table(index='gene', columns='gene_pos')

print("Total genes:", pivot_df.shape[0])

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")


# ATTENTION LAYER

class AttentionLayer(nn.Module):

    def __init__(self, feature_dim):

        super().__init__()

        self.attn = nn.Linear(feature_dim,1)

    def forward(self,x):

        weights = torch.softmax(self.attn(x),dim=1)

        context = (weights * x).sum(dim=1)

        return context

# CNN + ATTENTION MODEL

class PTMModel(nn.Module):

    def __init__(self):

        super().__init__()

        self.conv = nn.Conv1d(1,32,kernel_size=2)

        self.relu = nn.ReLU()

        self.attn = AttentionLayer(32)

        self.fc = nn.Sequential(

            nn.Linear(32,32),
            nn.ReLU(),

            nn.Linear(32,1)

        )

    def forward(self,x):

        x = self.conv(x)

        x = self.relu(x)

        x = x.permute(0,2,1)

        x = self.attn(x)

        x = self.fc(x)

        return x

# TRAIN FUNCTION

def train_model(model,X_train,y_train,X_test,epochs=200):

    model = model.to(device)

    criterion = nn.MSELoss()

    optimizer = optim.Adam(model.parameters(),lr=0.001)

    X_train = torch.tensor(X_train,dtype=torch.float32).to(device)
    y_train = torch.tensor(y_train,dtype=torch.float32).view(-1,1).to(device)

    X_test = torch.tensor(X_test,dtype=torch.float32).to(device)

    for epoch in range(epochs):

        model.train()

        optimizer.zero_grad()

        preds = model(X_train)

        loss = criterion(preds,y_train)

        loss.backward()

        optimizer.step()

    model.eval()

    with torch.no_grad():

        preds = model(X_test).cpu().numpy().flatten()

    return preds

kf = KFold(n_splits=5, shuffle=True, random_state=42)

results = []

# LOOP THROUGH PTMs

unique_ptms = pivot_df.columns.get_level_values(0).unique()

for ptm in unique_ptms:

    try:

        ptm_df = pivot_df[ptm]

        if -1 not in ptm_df.columns:
            continue

        feature_positions = [p for p in ptm_df.columns if 1 <= p <= 5]

        if len(feature_positions) < 5:
            continue

        ptm_df = ptm_df[[-1] + feature_positions]

        ptm_df = ptm_df.dropna(subset=[-1])

        ptm_df[feature_positions] = ptm_df[feature_positions].fillna(0)

        X = ptm_df[feature_positions].values
        y = ptm_df[-1].values

        X = np.nan_to_num(X)
        y = np.nan_to_num(y)

        scaler = StandardScaler()

        X = scaler.fit_transform(X)

        X = X.reshape(X.shape[0],1,X.shape[1])

        scores = []

        for train_idx,test_idx in kf.split(X):

            X_train,X_test = X[train_idx],X[test_idx]
            y_train,y_test = y[train_idx],y[test_idx]

            model = PTMModel()

            preds = train_model(model,X_train,y_train,X_test)

            score = r2_score(y_test,preds)

            scores.append(score)

        print("\nPTM:",ptm)
        print("Mean R2:",np.mean(scores))

        results.append({
            "PTM":ptm,
            "Mean_R2":np.mean(scores)
        })

    except:
        continue

# FINAL RESULTS


results_df = pd.DataFrame(results)

results_df = results_df.sort_values(by="Mean_R2",ascending=False)

print("\nBEST PTMs")

print(results_df.head(20))

results_df.to_csv("PTM_attention_results.csv",index=False)
